# SpiritOS server env

PORT=3001
NODE_ENV=development

# Prisma — SQLite for dev. Switch to "postgresql://..." + update
# prisma/schema.prisma to use Postgres in production.
DATABASE_URL=file:./savitaos.db

# REQUIRED. Long random string for express-session.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Filesystem root for the File Explorer app. Empty defaults to the user's
# home directory. Set to ./demo-filesystem to use the bundled demo data.
FS_ROOT=
MAX_TREE_DEPTH=4
TREE_CACHE_TTL=5000

# Terminal limits
TERMINAL_TIMEOUT=15000
TERMINAL_MAX_OUTPUT=50000

# CORS
CLIENT_URL=http://localhost:5173

# ─── IRIS Engine (Primary AI — Gemini) ──────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: Groq for faster intent routing
GROQ_API_KEY=

# Optional: Tavily for web search
TAVILY_API_KEY=

# Optional: OpenRouter for free-model fallback (https://openrouter.ai/)
# Uses 9+ free LLMs as fallback when Gemini hits rate limits
OPENROUTER_API_KEY=

# Engine config
AI_PRIMARY_ENGINE=iris           # 'iris' (Gemini primary) or 'spirit' (offline only)
AI_FALLBACK_TIMEOUT_MS=10000     # Fall back after this many ms
ENABLE_PERSISTENT_MEMORY=true    # Store user memories across sessions

# FALLBACK CHAIN: Gemini → OpenRouter free models → Spirit offline
# Without any API keys, the system uses the offline Spirit engine (lib/spirit.js).
