# SpiritOS client env — all vars are optional. Vite reads them at build time.

# ==================== Backend ==================== #
# Override only if you proxy the API through a different host.
# Default behaviour: relative '/api/...' goes through Vite's dev proxy to
# http://localhost:3001 (see vite.config.js).
VITE_API_URL=
VITE_WS_URL=ws://localhost:3001

# ==================== Gesture tuning ==================== #
# Cooldown between consecutive gesture firings (ms)
VITE_GESTURE_COOLDOWN=2000
# How long a non-pinch gesture must be held before it fires (ms)
VITE_GESTURE_HOLD_TIME=600
# Click cooldown so a held pinch doesn't spam clicks (ms)
VITE_CLICK_COOLDOWN=300
# Mouse smoothing — 0..1 (higher = snappier, lower = smoother)
VITE_MOUSE_SMOOTHING=0.55
# Pinch threshold — distance(thumb, index) / palm scale; below this fires a click
VITE_PINCH_THRESH=0.55

# ==================== App-window default sizes ==================== #
VITE_APP_FILEEXPLORER_WIDTH=900
VITE_APP_FILEEXPLORER_HEIGHT=600
VITE_APP_CALCULATOR_WIDTH=380
VITE_APP_CALCULATOR_HEIGHT=480
VITE_APP_NOTES_WIDTH=600
VITE_APP_NOTES_HEIGHT=500
